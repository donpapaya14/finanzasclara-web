---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="All articles" description="Articles on saving, investing, debt, budgeting and passive income — every claim backed by data.">
  <section class="section">
    <div class="container">
      <h1>All articles</h1>
      <p class="page-subtitle">Personal finance grounded in real data</p>
      <div class="articles-grid">
        {sortedPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding: 3rem 0; }
  h1 { margin-bottom: 0.25rem; }
  .page-subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
