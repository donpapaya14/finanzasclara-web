---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../utils/categories';
import type { Category } from '../utils/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = Object.entries(CATEGORIES) as [Category, (typeof CATEGORIES)[Category]][];
---

<BaseLayout title="FinanzasClara" description="Editorial personal finance for US & UK. Saving, investing, debt and budgeting — backed by real numbers, not hype.">
  <!-- Hero with Pexels finance imagery -->
  <section class="hero hero--finance">
    <div class="container hero__inner hero-grid">
      <div class="hero-text">
        <div class="eyebrow">Editorial personal finance</div>
        <h1 class="display hero__title">
          Money decisions,<br />
          <em>backed by real numbers</em>
        </h1>
        <p class="lede hero__subtitle">
          Saving, investing, debt and budgeting — analyzed with data, not hype.
          Practical guides for everyday US &amp; UK readers.
        </p>
        <div class="hero__actions">
          <a href="/blog" class="btn-primary">Read articles &rarr;</a>
          <a href="#categories" class="btn-ghost">Explore categories</a>
        </div>

        <div class="pop-chips" aria-label="Popular topics">
          <span class="pop-chips-label">Popular</span>
          <a href="/categoria/investing" class="pop-chip">Index funds</a>
          <a href="/categoria/savings" class="pop-chip">High-yield savings</a>
          <a href="/categoria/debt" class="pop-chip">Debt payoff</a>
          <a href="/categoria/budgeting" class="pop-chip">Zero-based budget</a>
          <a href="/categoria/passive-income" class="pop-chip">Passive income</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <img
          src="https://images.pexels.com/photos/4386442/pexels-photo-4386442.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt=""
          loading="eager"
          decoding="async"
        />
        <div class="hero-card hero-card--top">
          <span class="hero-card__label">High-yield savings APY</span>
          <span class="hero-card__num"><em>4.85</em>%</span>
        </div>
        <div class="hero-card hero-card--bottom">
          <span class="hero-card__label">S&amp;P 500 — 30Y avg</span>
          <span class="hero-card__num hero-card__num--green">+<em>10.2</em>%</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <div class="eyebrow">Recent</div>
          <h2 class="section-title">Latest articles</h2>
        </div>
        <a href="/blog" class="section__link">See all &rarr;</a>
      </div>
      <div class="articles-grid">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Numbers we trust — dark navy with stats -->
  <section class="section section--dark">
    <div class="container">
      <div style="text-align:center;max-width:680px;margin:0 auto">
        <div class="eyebrow eyebrow--on-dark" style="justify-content:center">Numbers we trust</div>
        <h2 class="section-title">Data, not opinions.</h2>
        <p class="lede" style="margin-top:14px">
          Every guide we publish is grounded in historical data, current rates, and verified sources — never gut feeling.
        </p>
      </div>
      <div class="stats-row">
        <div class="stat">
          <div class="stat__num"><em>10.2</em>%</div>
          <div class="stat__label">S&amp;P 500 30-year average annual return</div>
        </div>
        <div class="stat">
          <div class="stat__num">$<em>1,500</em></div>
          <div class="stat__label">Median monthly savings of US households who budget</div>
        </div>
        <div class="stat">
          <div class="stat__num"><em>7.2</em>%</div>
          <div class="stat__label">Average APR on a 5-year auto loan, May 2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="section section--alt">
    <div class="container">
      <div style="text-align:center;margin-bottom:36px">
        <div class="eyebrow" style="justify-content:center">Explore</div>
        <h2 class="section-title">By category</h2>
      </div>
      <div class="categories-grid">
        {categories.map(([key, cat]) => (
          <a href={`/categoria/${key}`} class={`cat-card cat-card--${key}`}>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YouTube CTA -->
  <section class="section">
    <div class="container yt-section">
      <div class="eyebrow" style="justify-content:center">Also on YouTube</div>
      <h2 class="section-title">Money tips in 60 seconds</h2>
      <p class="lede" style="margin:14px auto 26px;max-width:520px">
        Daily shorts backed by real numbers — quick decisions, no fluff.
      </p>
      <a href="https://youtube.com/@FinanzasClara-l3w" target="_blank" rel="noopener" class="btn-primary btn--lg">
        Visit channel &rarr;
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .hero-text { max-width: 620px; }

  /* Hero visual with floating data cards */
  .hero-visual {
    position: relative;
    border-radius: 22px;
    overflow: visible;
  }
  .hero-visual > img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: 22px;
    box-shadow: 0 30px 80px -40px rgba(10, 25, 41, 0.55);
  }
  .hero-card {
    position: absolute;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 14px 18px;
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 180px;
  }
  .hero-card--top    { top: 8%; left: -28px; }
  .hero-card--bottom { bottom: 14%; right: -28px; }
  .hero-card__label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
  }
  .hero-card__num {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 500;
    line-height: 1;
    color: var(--ink-1);
    letter-spacing: -0.02em;
  }
  .hero-card__num em {
    font-family: var(--font-mono);
    font-style: normal;
    font-weight: 600;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .hero-card__num--green em { color: var(--green); }

  /* Per-category accent edge */
  .cat-card--savings        { box-shadow: inset 4px 0 0 var(--green),   var(--shadow-sm); }
  .cat-card--investing      { box-shadow: inset 4px 0 0 var(--accent),  var(--shadow-sm); }
  .cat-card--debt           { box-shadow: inset 4px 0 0 var(--red),     var(--shadow-sm); }
  .cat-card--budgeting      { box-shadow: inset 4px 0 0 #7c3aed,        var(--shadow-sm); }
  .cat-card--passive-income { box-shadow: inset 4px 0 0 var(--amber),   var(--shadow-sm); }

  .yt-section {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { max-width: 480px; margin: 0 auto; }
    .hero-card--top    { left: -16px; }
    .hero-card--bottom { right: -16px; }
  }
  @media (max-width: 600px) {
    .hero__actions { flex-direction: column; align-items: stretch; }
    .hero__actions .btn-primary,
    .hero__actions .btn-ghost { width: 100%; justify-content: center; }
    .hero-card { min-width: 150px; padding: 12px 14px; }
    .hero-card__num { font-size: 22px; }
  }
</style>
