---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../utils/categories';
import type { Category } from '../utils/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = Object.entries(CATEGORIES) as [Category, (typeof CATEGORIES)[Category]][];
---

<BaseLayout title="FinanzasClara" description="Personal finance backed by real data. Practical, tested advice without the hype.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <h1 class="hero__title">Personal finance <span>backed by real data</span></h1>
      <p class="hero__subtitle">
        Saving, investing and money habits. Practical advice tested with numbers, not gimmicks.
      </p>
      <div class="hero__actions">
        <a href="/blog" class="btn btn--primary">Read articles</a>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Latest articles</h2>
        <a href="/blog" class="section__link">See all &rarr;</a>
      </div>
      <div class="articles-grid">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="section__heading-center">Explore by category</h2>
      <div class="categories-grid">
        {categories.map(([key, cat]) => (
          <a href={`/categoria/${key}`} class={`cat-card cat-card--${key}`}>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- YouTube CTA -->
  <section class="section">
    <div class="container yt-section">
      <div class="yt-section__text">
        <h2>Also on YouTube</h2>
        <p>Quick money tips in 60 seconds. Daily shorts backed by real numbers.</p>
        <a href="https://youtube.com/@FinanzasClara-l3w" target="_blank" rel="noopener" class="btn btn--outline">
          Visit channel
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #0A2E1A 0%, #1B3D2E 50%, #0A2E1A 100%);
    color: white;
    padding: 5rem 0 4rem;
  }
  .hero__inner { max-width: 700px; }
  .hero__title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.15;
    color: white;
  }
  .hero__title span { color: var(--color-primary-light); }
  .hero__subtitle {
    font-size: 1.125rem;
    color: #D1D5DB;
    margin-top: 1.25rem;
    line-height: 1.7;
  }
  .hero__actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
  .hero .btn--outline {
    color: white;
    border-color: rgba(255,255,255,0.3);
  }
  .hero .btn--outline:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }
  .section { padding: 4rem 0; }
  .section--alt { background: #F3F4F6; }
  .section__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .section__link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  .section__heading-center {
    text-align: center;
    margin-bottom: 2rem;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .cat-card {
    display: block;
    padding: 1.5rem;
    border-radius: var(--radius);
    color: white;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .cat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    color: white;
  }
  .cat-card h3 { font-size: 1.125rem; margin-bottom: 0.5rem; color: white; }
  .cat-card p { font-size: 0.8125rem; opacity: 0.9; }
  
  
  
  
  
    .cat-card--savings { background: #2E7D32; }
  .cat-card--investing { background: #1565C0; }
  .cat-card--debt { background: #C62828; }
  .cat-card--budgeting { background: #6A1B9A; }
  .cat-card--passive-income { background: #E65100; }
  .newsletter-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
  }
  .newsletter-hero__inner { text-align: center; max-width: 550px; margin: 0 auto; }
  .newsletter-hero h2 { color: white; font-size: 1.75rem; }
  .newsletter-hero p { color: #FECACA; margin: 1rem 0 1.5rem; }
  .newsletter-hero .btn--primary {
    background: white;
    color: var(--color-primary);
  }
  .newsletter-hero .btn--primary:hover { background: #FFF5F5; }
  .btn--lg { padding: 0.875rem 2rem; font-size: 1rem; }
  .yt-section {
    text-align: center;
    max-width: 550px;
    margin: 0 auto;
  }
  .yt-section p {
    color: var(--color-text-light);
    margin: 0.75rem 0 1.5rem;
  }
  @media (max-width: 600px) {
    .hero { padding: 3rem 0; }
    .hero__title { font-size: 2rem; }
    .hero__actions { flex-direction: column; }
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>
