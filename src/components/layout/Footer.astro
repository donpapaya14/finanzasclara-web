---
const year = new Date().getFullYear();
const categories = [
  { href: '/categoria/savings',         label: 'Savings' },
  { href: '/categoria/investing',       label: 'Investing' },
  { href: '/categoria/debt',            label: 'Debt' },
  { href: '/categoria/budgeting',       label: 'Budgeting' },
  { href: '/categoria/passive-income',  label: 'Passive Income' },
];
const legal = [
  { href: '/legal-notice',   label: 'Legal' },
  { href: '/privacy-policy', label: 'Privacy' },
  { href: '/cookie-policy',  label: 'Cookies' },
];
const sites = [
  { href: 'https://vida-sana-360.com',      label: 'VidaSana360' },
  { href: 'https://saludlongevidad.org',    label: 'SaludLongevidad' },
  { href: 'https://catbrothers.uk',         label: 'CatBrothers' },
  { href: 'https://espaciointeligente.org', label: 'Espacio Inteligente' },
  { href: 'https://cash-cafe.org',          label: 'Cash Café' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="topbar__brand" style="text-decoration:none">
        <span class="brand-mark" aria-hidden="true">FC</span>
        <span class="brand-name">Finanzas<em>Clara</em></span>
      </a>
      <p class="lede" style="font-size:13.5px;margin-top:14px;max-width:360px;color:var(--ink-3)">
        Editorial personal finance for US &amp; UK. Saving, investing, debt and budgeting — backed by real numbers.
      </p>
    </div>

    <nav class="site-footer__col" aria-label="Categories">
      <h4>Categories</h4>
      <ul>
        {categories.map(c => <li><a href={c.href}>{c.label}</a></li>)}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Connect">
      <h4>Connect</h4>
      <ul>
        <li><a href="https://www.youtube.com/@FinanzasClara-l3w" target="_blank" rel="noopener">YouTube</a></li>
        <li><a href="/rss.xml">RSS</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <nav class="site-footer__col site-footer__col--sites" aria-label="Our sites">
      <h4>Our sites</h4>
      <ul>
        {sites.map(s => (
          <li><a href={s.href} target="_blank" rel="noopener">{s.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bar">
    <div class="container site-footer__bar-inner">
      <span class="micro">&copy; {year} FinanzasClara · Educational content, not professional financial advice</span>
      <ul class="site-footer__legal">
        {legal.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding: 56px 0 0;
    margin-top: 64px;
    background: var(--surface-2);
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 32px;
    padding-bottom: 40px;
  }
  .site-footer__col h4 {
    color: var(--ink-1);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }
  .site-footer__col ul { list-style: none; padding: 0; margin: 0; }
  .site-footer__col li { margin-bottom: 8px; }
  .site-footer__col a {
    color: var(--ink-2);
    font-size: 13.5px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-footer__col a:hover { color: var(--accent); }

  .site-footer__bar {
    border-top: 1px solid var(--line);
    padding: 18px 0 28px;
  }
  .site-footer__bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .site-footer__legal {
    list-style: none;
    display: flex;
    gap: 18px;
    margin: 0;
    padding: 0;
  }
  .site-footer__legal a {
    font-size: 12px;
    color: var(--ink-3);
    text-decoration: none;
  }
  .site-footer__legal a:hover { color: var(--ink-1); }

  @media (max-width: 880px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .site-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .site-footer__inner { grid-template-columns: 1fr; }
    .site-footer__bar-inner { justify-content: flex-start; }
  }
</style>
