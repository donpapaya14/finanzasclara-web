---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Articles' },
  { href: '/categoria/savings', label: 'Savings' },
  { href: '/categoria/investing', label: 'Investing' },
  { href: '/categoria/debt', label: 'Debt' },
  { href: '/categoria/budgeting', label: 'Budgeting' },
  { href: '/categoria/passive-income', label: 'Passive Income' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="topbar">
  <div class="container topbar__inner">
    <a href="/" class="topbar__brand" aria-label="FinanzasClara — Home">
      <span class="brand-mark" aria-hidden="true">FC</span>
      <span class="brand-name">Finanzas<em>Clara</em></span>
    </a>

    <nav class="topnav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['topnav-link', { active: isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="topbar__menu-btn" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    background: rgba(255, 255, 255, 0.82);
    border-bottom: 1px solid var(--line);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    gap: 18px;
  }
  .topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink-1);
    flex-shrink: 0;
  }
  .topbar__brand:hover .brand-name em { color: var(--accent-dark); }

  .topnav-links {
    display: flex;
    gap: 22px;
    font-size: 13.5px;
    color: var(--ink-2);
  }
  .topnav-link {
    cursor: pointer;
    text-decoration: none;
    color: var(--ink-2);
    transition: color 0.15s;
    font-weight: 500;
    letter-spacing: 0.005em;
    padding: 6px 2px;
    position: relative;
  }
  .topnav-link:hover { color: var(--accent); }
  .topnav-link.active {
    color: var(--ink-1);
    font-weight: 600;
  }
  .topnav-link.active::after {
    content: "";
    position: absolute;
    left: 2px; right: 2px; bottom: -2px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  .topbar__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .topbar__menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink-1);
    border-radius: 2px;
    transition: 0.3s;
  }

  @media (max-width: 980px) {
    .topnav-links { display: none; }
    .topbar__menu-btn { display: flex; }
    .topnav-links.mobile-open {
      display: flex;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(16px);
      padding: 18px 28px;
      border-bottom: 1px solid var(--line);
      gap: 14px;
    }
  }
</style>

<script>
  const btn = document.querySelector('.topbar__menu-btn');
  const nav = document.querySelector('.topnav-links');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('mobile-open');
  });
</script>
